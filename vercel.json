{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ],
  "redirects": [
    { "source": "/docs", "destination": "/", "permanent": false },
    { "source": "/documentation", "destination": "/", "permanent": false },
    { "source": "/login", "destination": "/login.html", "permanent": false }
  ]
}
